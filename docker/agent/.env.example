# ── Jarvis environment config ─────────────────────────────────────────────────
# Copy this to .env and fill in real values.
# .env is gitignored — never commit it.

# Claude API key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Jarvis's Signal phone number in E.164 format, e.g. +14155550100
JARVIS_NUMBER=+1XXXXXXXXXX

# Your phone number in E.164 — only this number can command Jarvis.
# Comma-separated for multiple users: +14155550101,+14155550102
ALLOWED_SENDERS=+1XXXXXXXXXX

# Proxmox SSH (defaults match the project's known config)
PROXMOX_HOST=192.168.4.42
PROXMOX_USER=root
SSH_KEY_PATH=/home/jarvis/.ssh/identity.rsa

# Path to SSH private key on the HOST machine (mounted into the container)
SSH_KEY_HOST_PATH=~/.ssh/identity.rsa

# Overseerr API key — Settings → General → API Key in the Overseerr UI
OVERSEERR_URL=http://192.168.4.124:5055
OVERSEERR_API_KEY=

# Sonarr / Radarr (used for service status checks)
SONARR_URL=http://192.168.4.124:8989
RADARR_URL=http://192.168.4.124:7878

# Claude model to use
CLAUDE_MODEL=claude-sonnet-4-6

# How often to poll Signal for new messages (seconds)
POLL_INTERVAL=3
