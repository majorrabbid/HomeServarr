# ── Jarvis environment config ─────────────────────────────────────────────────
# Copy this to .env and fill in real values.
# .env is gitignored — never commit it.

# Claude API key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Jarvis's Signal phone number in E.164 format (international dialling code + number, no spaces).
# Australia: drop the leading 0 from the mobile number and prefix with +61
# e.g. 0412 345 678 → +61412345678
# This should be a dedicated SIM used only for Jarvis — NOT your personal number.
# Signal CLI will register this number and receive SMS verification to the physical SIM.
JARVIS_NUMBER=+614XXXXXXXX

# Your personal Australian mobile in E.164 — only this number can command Jarvis.
# Comma-separated for multiple users: +61412345678,+61498765432
ALLOWED_SENDERS=+614XXXXXXXX

# Proxmox SSH (defaults match the project's known config)
PROXMOX_HOST=192.168.4.42
PROXMOX_USER=root
SSH_KEY_PATH=/home/jarvis/.ssh/identity.rsa

# Path to SSH private key on the HOST machine (mounted into the container)
SSH_KEY_HOST_PATH=~/.ssh/identity.rsa

# Overseerr API key — Settings → General → API Key in the Overseerr UI
OVERSEERR_URL=http://192.168.4.124:5055
OVERSEERR_API_KEY=

# Sonarr / Radarr (used for service status checks)
SONARR_URL=http://192.168.4.124:8989
RADARR_URL=http://192.168.4.124:7878

# Claude model to use
CLAUDE_MODEL=claude-sonnet-4-6

# How often to poll Signal for new messages (seconds)
POLL_INTERVAL=3
