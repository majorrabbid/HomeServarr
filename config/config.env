# HomeServarr Configuration
# Copy this file to /opt/homeservarr/config.env on the Proxmox host
# and update with actual values. Add to .gitignore to avoid committing secrets.

# Media Prune and Alert Settings (media_prune_and_alert.sh)
SONARR_URL=http://192.168.4.124:8989
SONARR_API_KEY=APIKEYHERE
RADARR_URL=http://192.168.4.124:7878
RADARR_API_KEY=APIKEYHERE
WARN_PCT=85
CRIT_PCT=90
PRUNE_SONARR_OLDER_THAN_DAYS=60
PRUNE_RADARR_OLDER_THAN_DAYS=120
PRUNE_SONARR_ENDED_ONLY=1
PRUNE_RADARR_UNMONITORED_ONLY=1
PRUNE_RADARR_ADD_EXCLUSION=1
PRUNE_RADARR_DELETE_FILES=1
DRY_RUN=0
NTFY_ENABLE=0
NTFY_URL=https://ntfy.sh
NTFY_TOPIC=arr-disk-alerts

# Health Check Settings (health_check.sh)
HEALTH_EMAIL=majorrabbid@gmail.com

# Container Patching Settings (patch_all_containers.sh)
PATCH_DRY_RUN=0

# Host Patching Settings (patch_pve_host.sh)
HOST_PATCH_DRY_RUN=0

# DNS Update Settings (update_pihole_hosts.sh)
# Hostname-IP mappings are hardcoded in script, but could be externalized later